{
  "name": "favoritable",
  "version": "0.2.0",
  "private": true,
  "description": "A simple and efficient system for storing, organizing, and accessing personal bookmarks anytime, anywhere.",
  "keywords": [
    "bookmarks",
    "favoritable"
  ],
  "homepage": "https://github.com/trystan2k/favoritable#readme",
  "bugs": {
    "url": "https://github.com/trystan2k/favoritable/issues"
  },
  "author": "Thiago Mendonca",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trystan2k/favoritable"
  },
  "type": "module",
  "scripts": {
    "predev": "pnpm db:bootstrap:auth && pnpm tokens:build",
    "dev": "vite",
    "prebuild": "pnpm tokens:build",
    "build": "vite build",
    "build:e2e:preview": "pnpm tokens:build && E2E_PREVIEW=true vite build",
    "preview": "vite preview",
    "tokens:build": "style-dictionary build --config design-tokens/style-dictionary.config.mjs",
    "prepare": "husky",
    "pretest": "pnpm db:bootstrap:auth && pnpm tokens:build",
    "test": "vitest run --coverage",
    "test:browser:setup": "playwright install --with-deps chromium",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project chromium --grep @smoke",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:setup": "playwright install --with-deps chromium webkit",
    "lint": "pnpm lint:oxlint && pnpm lint:stylelint",
    "lint:oxlint": "oxlint --deny-warnings",
    "lint:stylelint": "stylelint \"src/**/*.css\" --allow-empty-input",
    "lint:fix": "pnpm lint:fix:oxlint && pnpm lint:fix:stylelint",
    "lint:fix:oxlint": "oxlint --fix --deny-warnings",
    "lint:fix:stylelint": "stylelint \"src/**/*.css\" --allow-empty-input --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "preview:e2e": "pnpm db:bootstrap:auth && ([ \"$E2E_SKIP_BUILD\" = \"true\" ] || pnpm build:e2e:preview) && E2E_PREVIEW=true vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "db:generate": "drizzle-kit generate",
    "db:bootstrap:auth": "node ./scripts/bootstrap-auth-db.mjs",
    "db:migrate": "drizzle-kit migrate",
    "auth:schema": "pnpm dlx @better-auth/cli generate --config src/features/auth/server/auth.server.ts --output src/db/schema/auth.ts --yes",
    "complete-check": "pnpm knip && pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build && pnpm test:e2e",
    "knip": "knip",
    "knip:fix": "pnpm knip --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth/drizzle-adapter": "~1.6.16",
    "@cloudflare/vite-plugin": "~1.40.0",
    "@libsql/client": "~0.17.3",
    "@tanstack/react-router": "~1.170.11",
    "@tanstack/react-start": "~1.168.20",
    "better-auth": "~1.6.16",
    "drizzle-orm": "~0.45.2",
    "react": "~19.2.7",
    "react-dom": "~19.2.7"
  },
  "devDependencies": {
    "@commitlint/cli": "~21.0.2",
    "@commitlint/config-conventional": "~21.0.2",
    "@playwright/test": "~1.60.0",
    "@tanstack/devtools-vite": "~0.7.0",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.2",
    "@types/node": "~25.9.1",
    "@types/react": "~19.2.16",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.2",
    "@vitest/browser-playwright": "~4.1.8",
    "@vitest/coverage-v8": "~4.1.8",
    "drizzle-kit": "~0.31.10",
    "husky": "~9.1.7",
    "knip": "~6.15.0",
    "lint-staged": "~17.0.7",
    "oxfmt": "~0.53.0",
    "oxlint": "~1.68.0",
    "oxlint-tsgolint": "~0.23.0",
    "style-dictionary": "~5.4.4",
    "stylelint": "~17.12.0",
    "stylelint-config-standard": "~40.0.0",
    "typescript": "~6.0.3",
    "vite": "~8.0.16",
    "vite-plugin-killer-instincts": "~1.1.0",
    "vitest": "~4.1.8"
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.5.0"
  },
  "packageManager": "pnpm@11.5.2"
}
