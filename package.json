{
  "name": "favoritable",
  "description": "A simple and efficient system for storing, organizing, and accessing personal bookmarks anytime, anywhere.",
  "version": "0.0.1",
  "author": "Thiago Mendonca",
  "homepage": "https://github.com/trystan2k/favoritable#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trystan2k/favoritable"
  },
  "bugs": {
    "url": "https://github.com/trystan2k/favoritable/issues"
  },
  "keywords": [
    "bookmarks",
    "favoritable"
  ],
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "complete-check": "pnpm test && pnpm build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@tailwindcss/vite": "~4.1.18",
    "@tanstack/react-devtools": "~0.10.5",
    "@tanstack/react-query": "~5.100.0",
    "@tanstack/react-query-devtools": "~5.100.0",
    "@tanstack/react-router": "~1.170.0",
    "@tanstack/react-router-devtools": "~1.167.0",
    "@tanstack/react-router-ssr-query": "~1.167.1",
    "@tanstack/react-start": "~1.168.20",
    "@tanstack/router-plugin": "~1.168.14",
    "better-auth": "~1.5.3",
    "better-sqlite3": "~12.6.2",
    "drizzle-kit": "~0.31.9",
    "drizzle-orm": "~0.45.1",
    "lucide-react": "~0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "~19.2.0",
    "react-dom": "~19.2.0",
    "tailwindcss": "~4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "~0.5.16",
    "@tanstack/devtools-vite": "~0.7.0",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.0",
    "@types/better-sqlite3": "~7.6.0",
    "@types/node": "~22.10.2",
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "@vitejs/plugin-react": "~6.0.1",
    "dotenv": "~17.3.1",
    "jsdom": "~28.1.0",
    "tsx": "~4.21.0",
    "typescript": "~6.0.2",
    "vite": "~8.0.0",
    "vitest": "~4.1.5"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=10.20.0"
  }
}
