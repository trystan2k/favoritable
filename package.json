{
  "name": "favoritable",
  "description": "API to handle favorites links",
  "version": "0.0.1",
  "author": "Thiago Mendonca",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/trystan2k/favoritable#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trystan2k/favoritable"
  },
  "bugs": {
    "url": "https://github.com/trystan2k/favoritable/issues"
  },
  "keywords": [
    "bookmarks",
    "favoritable"
  ],
  "license": "MIT",
  "scripts": {
    "clean": "find . -name .git -prune -o -type d \\( -name \"node_modules\" -o -name \"dist\" \\) -prune -exec rm -rf '{}' +",
    "complete-check": "pnpm typecheck && pnpm check && pnpm knip && pnpm test:coverage && pnpm build",
    "prepare": "[ -d '.git' ] && husky install || echo 'skipping husky'",
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:fix": "turbo run format:fix",
    "check": "turbo run check",
    "check:fix": "turbo run check:fix",
    "knip": "turbo run knip",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage"
  },
  "devDependencies": {
    "husky": "~9.1.7",
    "lint-staged": "~16.1.5",
    "oxfmt": "~0.47.0",
    "oxlint": "~1.62.0",
    "turbo": "~2.9.14"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,cts,mts,jsx,tsx,json,jsonc,css,md,yml,yaml}": [
      "pnpm exec oxfmt --config .oxfmtrc.json --no-error-on-unmatched-pattern"
    ],
    "*.{js,ts,cjs,mjs,cts,mts,jsx,tsx}": [
      "pnpm exec oxlint --config .oxlintrc.json --fix"
    ]
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.20.0"
  }
}
