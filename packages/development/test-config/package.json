{
  "name": "@favoritable/test-config",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./vitest.config.ts",
  "types": "./vitest.config.ts",
  "exports": {
    ".": "./vitest.config.ts",
    "./vitest.config": "./vitest.config.ts"
  },
  "scripts": {
    "knip": "knip",
    "lint": "pnpm -w exec oxlint --config .oxlintrc.json packages/development/test-config/vitest.config.ts",
    "lint:fix": "pnpm -w exec oxlint --config .oxlintrc.json --fix packages/development/test-config/vitest.config.ts",
    "format": "pnpm -w exec oxfmt --config .oxfmtrc.json packages/development/test-config",
    "format:check": "pnpm -w exec oxfmt --config .oxfmtrc.json --check packages/development/test-config",
    "format:fix": "pnpm format",
    "check": "pnpm lint && pnpm format:check",
    "check:fix": "pnpm lint:fix && pnpm format"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "~3.2.4",
    "knip": "~5.62.0",
    "vitest": "~3.2.4"
  }
}
