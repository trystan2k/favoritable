BETTER_AUTH_SECRET=replace-with-32-plus-char-secret
# Use local dev origin by default. Google OAuth callback becomes ${BETTER_AUTH_URL}/api/auth/callback/google.
# Local default values for Google Cloud:
# - Authorized JavaScript origin: http://localhost:4000
# - Authorized redirect URI: http://localhost:4000/api/auth/callback/google
# If you change BETTER_AUTH_URL, update both Google Cloud values to match exactly.
BETTER_AUTH_URL=http://localhost:4000
DATABASE_URL=file:./data/favoritable.db
# Required when DATABASE_URL uses secured libsql:// / Turso auth.
DATABASE_AUTH_TOKEN=
# Set both or leave both unset. Partial Google OAuth config stays disabled and logs a dev warning.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional comma-separated list for extra origins. Required outside local/test deploys.
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:4000,http://127.0.0.1:4173
# Placeholder provider scaffolding for later auth tasks. Leave unset in FAV-1.
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# Optional local/CI-only secret for authenticated smoke bootstrap via /api/auth/test-session.
E2E_TEST_SESSION_SECRET=
# Optional Google OAuth E2E account for e2e/tests/google-oauth.spec.ts. Spec skips when unset.
E2E_GOOGLE_TEST_EMAIL=
E2E_GOOGLE_TEST_PASSWORD=
